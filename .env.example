# Copy this file to .env for local testing. Never commit .env.

# ── Google OAuth (primary auth method) ──────────────────────────────────────
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# Type: OAuth 2.0 Web Application
# Authorized redirect URI: https://your-app.up.railway.app  (and http://localhost:8501 for local dev)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
APP_URL=https://your-app.up.railway.app
ALLOWED_EMAILS=vivek@example.com,teammate@example.com

# ── Password fallback (used only if GOOGLE_CLIENT_ID is not set) ─────────────
DASHBOARD_PASSWORD=choose-a-strong-password

# ── Anthropic — Claude API key ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Drive — paste the full contents of venue_extractor_service_account_key.json as one line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}

# ── Xano endpoints ───────────────────────────────────────────────────────────
XANO_BASE_URL=https://xqtb-2ma7-ijfy.n7e.xano.io/api:GynP5T1B
XANO_SUMMARY_ENDPOINT=https://xqtb-2ma7-ijfy.n7e.xano.io/api:GynP5T1B/extracted_pdf_data
XANO_PRICING_ENDPOINT=https://xqtb-2ma7-ijfy.n7e.xano.io/api:GynP5T1B/venue_pricing
XANO_GET_ENDPOINT=https://xqtb-2ma7-ijfy.n7e.xano.io/api:GynP5T1B/wptp_pdfs
